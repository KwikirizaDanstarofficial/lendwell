{
  "name": "lendwell",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "author": {
    "name": "Lendwell",
    "email": "kwikirizadan55@gmail.com"
  },
  "description": "Cooperative Management Platform",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate:pg",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "electron:compile": "tsc -p electron/tsconfig.json && echo '{\"type\":\"commonjs\"}' > electron/dist/package.json",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron:build:linux": "npm run build && npm run electron:compile && electron-builder --linux",
    "electron:build:win": "npm run build && npm run electron:compile && electron-builder --win",
    "electron:build:mac": "npm run build && npm run electron:compile && electron-builder --mac",
    "electron:build:all": "npm run build && npm run electron:compile && electron-builder --linux --win",
    "electron:pack": "npm run electron:compile && electron-builder --dir"
  },
  "build": {
    "appId": "com.lendwell.desktop",
    "productName": "Lendwell",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "electron/dist/**",
      "!electron/dist/**/*.ts",
      "!electron/dist/**/*.map",
      "!.env",
      "!**/.env",
      "!**/.env.*",
      "!**/secrets*",
      "!config-server/**"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "nextapp",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "nextapp/node_modules"
      },
      {
        "from": ".next/static",
        "to": "nextapp/.next/static"
      },
      {
        "from": "public",
        "to": "nextapp/public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/512x512.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons/512x512.png",
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Office"
    },
    "deb": {
      "afterInstall": "build/deb-postinstall.sh"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icons/icon.ico"
    },
    "publish": null
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@powersync/react": "^1.10.0",
    "@powersync/web": "^1.38.2",
    "@react-pdf/renderer": "^4.3.2",
    "@remixicon/react": "^4.9.0",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-table": "^8.21.3",
    "ag-grid-community": "^35.3.0",
    "ag-grid-react": "^35.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "comms-sdk": "^1.0.2",
    "driver.js": "^1.4.0",
    "drizzle-kit": "^0.18.1",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "got": "^11.8.6",
    "lucide-react": "^1.7.0",
    "minimatch": "^9.0.5",
    "next": "^16.2.3",
    "next-pwa": "^2.0.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/electron": "^1.6.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-pdf": "^5.0.7",
    "concurrently": "^9.1.2",
    "electron": "^36.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.8.3",
    "sharp": "^0.34.5",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.3"
  }
}
